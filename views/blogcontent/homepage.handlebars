<div id="blogs" class="container">
    <div class="row justify-content-center bg-secondary">
        {{#if blogPublished.length}}
            <ul class="list-group list-group-flush w-100" id="articleList">
                {{#each blogPublished}}
                    <li class="list-group-item bg-secondary border-0 article-item"
                        data-title="{{this.title}}"
                        data-username="{{this.username}}"
                        data-date="{{this.date}}">
                        <div class="card bg-dark text-light shadow-sm">
                            <div class="card-body">
                                <nav class="navbar navbar-dark bg-dark px-0">
                                    <div class="container-fluid ">
                                        <a class="navbar-brand text-success" href="/homepage/read/{{this.blogid}}">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-journals" viewBox="0 0 16 16">
                                                <path d="M5 0h8a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2 2 2 0 0 1-2 2H3a2 2 0 0 1-2-2h1a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1H1a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v9a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1H3a2 2 0 0 1 2-2"/>
                                                <path d="M1 6v-.5a.5.5 0 0 1 1 0V6h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1zm0 3v-.5a.5.5 0 0 1 1 0V9h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1zm0 2.5v.5H.5a.5.5 0 0 0 0 1h2a.5.5 0 0 0 0-1H2v-.5a.5.5 0 0 0-1 0"/>
                                            </svg>
                                            Click here to read</a>
                                    </div>
                                </nav>
                                <h4 class="fw-bold">{{this.title}}</h4>
                                <small>by {{this.username}}</small><br>
                                <small class="text-secondary">
                                    Created on {{this.date}}
                                </small>
                                <br/>
                                <br>
                                <div class="d-flex align-items-center gap-2">
                                    <button
                                            class="btn btn-sm like-btn {{#if this.userLiked}}btn-danger disabled{{else}}btn-outline-danger{{/if}}"
                                            data-blogid="{{this.blogid}}"
                                            data-liked="{{this.userLiked}}"
                                            {{#if this.userLiked}}disabled{{/if}}
                                    >
                                        {{#if userLiked}}❤️ Liked{{else}}🤍 Like{{/if}}
                                    </button>
                                    <span id="likeCount" class="text-muted">
        {{likeCount}} likes
    </span>
                                </div>
                                <br/>

                            </div>
                        </div>
                    </li>
                {{/each}}
            </ul>
        {{else}}
            <p class="text-muted text-center">
                No blogs published yet.
            </p>
        {{/if}}
    </div>
    <br/>
</div>

<script>
    const sortSelect = document.querySelector('#sortSelect');
    const articleList = document.querySelector('#articleList');

    sortSelect.addEventListener("change", function() {
        // Get the selected value
        const sortValue = this.value;

        // Checking if we have articles to sort
        if (!articleList) return;

        // Get all article items
        const items = Array.from(articleList.querySelectorAll(".article-item"));

        // If no items or no sort value selected, do nothing
        if (items.length === 0 || !sortValue) return;

        // Sort the items
        items.sort((a, b) => {
            if (sortValue === 'username') {
                const aUsername = a.getAttribute('data-username') || '';
                const bUsername = b.getAttribute('data-username') || '';
                return aUsername.localeCompare(bUsername);
            }
            else if (sortValue === 'usernamed') {
                const aUsername = a.getAttribute('data-username') || '';
                const bUsername = b.getAttribute('data-username') || '';
                return bUsername.localeCompare(aUsername);
            }
            else if (sortValue === 'title') {
                const aTitle = a.getAttribute('data-title') || '';
                const bTitle = b.getAttribute('data-title') || '';
                return aTitle.localeCompare(bTitle);
            }
            else if (sortValue === 'titled') {
                const aTitle = a.getAttribute('data-title') || '';
                const bTitle = b.getAttribute('data-title') || '';
                return bTitle.localeCompare(aTitle);
            }
            else if (sortValue === 'date') {
                const aDate = a.getAttribute('data-date') || '';
                const bDate = b.getAttribute('data-date') || '';
                // For date comparison
                return new Date(aDate) - new Date(bDate);
            }
            else if (sortValue === 'dated') {
                const aDate = a.getAttribute('data-date') || '';
                const bDate = b.getAttribute('data-date') || '';
                // For date comparison
                return new Date(bDate) - new Date(aDate);
            }

            return 0;
        });

        // Clear the list and re-add sorted items
        articleList.innerHTML = '';
        items.forEach(item => {
            articleList.appendChild(item);
        });
    });

    document.querySelectorAll('.like-btn').forEach(btn => {
        btn.addEventListener('click', () => {

            // 🔒 Already liked? Do nothing
            if (btn.dataset.liked === 'true') return;

            const blogid = btn.dataset.blogid;
            const countEl = btn.nextElementSibling;

            fetch(`/homepage/like/${blogid}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (!data.liked) return;

                        // Lock state
                        btn.dataset.liked = 'true';
                        btn.disabled = true;

                        // Update count
                        const count = parseInt(countEl.innerText);
                        countEl.innerText = `${count + 1} likes`;

                        // Update UI
                        btn.className = 'btn btn-sm like-btn btn-danger disabled';
                        btn.innerText = '❤️ Liked';
                    });
        });
    });

</script>