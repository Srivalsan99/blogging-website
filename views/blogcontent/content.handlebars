    </div>
  </div>
</div>
    <p></p>

<h1 >Write your Blog</h1>
    <p></p>
    <p></p>

    <p></p>
    <h3>heading</h3>
    <input type="input" name="heading" class="w-75 justify-content-centre bg-secondary">
    <p></p>
    <h3>Body:</h3>
    <p></p>
    <div class="form-group" id="editor"></div>
    <input type="hidden" name="content" id="quillContent">
    <input type="hidden" name="'blogid" value="{{blogid}}">
</form>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
  const quill = new Quill('#editor', {
    modules: {
      toolbar: [
          [{ list: 'ordered' }, { list: 'bullet' }],
        [{ header: [1, 2, 3, 4, 5, 6, false] }],
        ['bold', 'italic', 'underline'],
        ['image', 'code-block'],
      ],
    },
    placeholder: 'Compose an epic...',
    theme: 'snow',
  });

  // For Create Part
  const form = document.querySelector('#publishForm');
  form.onsubmit = function(e) {
    const headingInput = document.querySelector('input[name="heading"]');
    const heading = headingInput.value.trim();
    {{!-- e.preventDefault(); --}}
    const htmlContent = quill.root.innerHTML;
    const plainText = quill.getText().trim(); // Quill plain text
    // console.log(htmlContent)
    // Validation
    if (!heading) {
      e.preventDefault();
      alert("Please enter a heading!");
      return false;
    }

    if (!plainText) {
      e.preventDefault();
      alert("Please write something in the blog body!");
      return false;
    }

    const sizeMB = new Blob([htmlContent]).size / (1024 * 1024);
    const maxMB = 250;
    if (sizeMB > maxMB) {
      e.preventDefault();
      alert(`Your blog content is too large (~${Math.round(sizeMB)} MB).`);
      return false;
    }

    // Put HTML content into hidden input so server receives it
    document.querySelector('#quillContent').value = htmlContent;
    console.log('Final')
    // console.log(document.querySelector('#quillContent').value)
  };

</script>

