<nav class="navbar navbar-expand-lg navbar-dark bg-dark ">
    <a href="/" class="navbar-brand gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
             class="bi bi-box-arrow-right" viewBox="0 0 16 16">
            <path fill-rule="evenodd"
                  d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/>
            <path fill-rule="evenodd"
                  d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/>
        </svg>
        <span>Back to Explore</span>
    </a>
    <div class="d-flex align-items-center gap-2">
        <button
                class="btn btn-sm like-btn {{#if this.userLiked}}btn-danger{{else}}btn-outline-danger{{/if}}"
                data-blogid="{{this.blogid}}"
                data-liked="{{this.userLiked}}"
        >
            {{#if userLiked}}❤️ disabled{{else}}🤍 Like{{/if}}
        </button>

        <span id="likeCount" class="text-muted">
        {{likeCount}} likes
    </span>
    </div>
</nav>

<div class="container-fluid vh-100">
    <div class="row h-100">

        <!-- Blog Content -->
        <div class="col-9 h-100 p-0">
            <div class="card bg-dark text-light shadow rounded-0 h-100">
                <div class="card-body overflow-auto h-100">

                    <h2 class="fw-bold mb-2">{{title}}</h2>
                    <p class="text-secondary mb-3">
                        by <strong>{{author}}</strong>
                    </p>
                    <hr class="border-secondary">
                    <div id="blogContent">
                        {{{content}}}
                    </div>

                </div>
            </div>
        </div>

        <!-- Comments Section -->
            {{> comments}}
    </div>
</div>

<script>
    const likeBtn = document.querySelector('.like-btn');
    const likeCount = document.querySelector('#likeCount');


    likeBtn.addEventListener('click', () => {
        // 🔒 Prevent clicking again
        if (likeBtn.dataset.liked === 'true') return;

        const blogid = likeBtn.dataset.blogid;

        fetch(`/homepage/like/${blogid}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (!data.liked) return;

                    likeBtn.dataset.liked = 'true';

                    const currentCount = parseInt(likeCount.innerText);
                    likeCount.innerText = `${currentCount + 1} likes`;

                    likeBtn.className = 'btn btn-sm like-btn btn-danger disabled';
                    likeBtn.innerText = '❤️ Liked';
                    likeBtn.disabled = true; // 🔐 hard lock
                });
    });
</script>
