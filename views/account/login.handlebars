
<div class="container-sm text-light">
    {{#if loginError}}
        <script>
            alert("Invalid Credentials! Please try again.");
        </script>
    {{/if}}
    <br/>
    <div class="d-flex align-items-center">

        <a href="/">
                <p class="mb-0 me-2">Go to Blog Page
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-box-arrow-right" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/>
                <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/>
            </svg>
                </p>
        </a>

    </div>


    <br/>
    <h1>Please Log in</h1>
    <div class="form-text text-dark">World's No 1 blogging website</div>

    <br/>

    <form action="/account/login" method="post">
        <div class="mb-3">
            <label for="userid" class="form-label">User ID:</label>
            <input type="text" class="form-control bg-secondary" id="userid" name="userid" required>

        </div>

        <div class="mb-3">
            <label for="password" class="form-label">Password:</label>
            <input type="password" class="form-control bg-secondary" id="password" name="password" required>
        </div>
        <br/>
        <div class="container-fluid">
            <button type="button" onclick="window.location.href='/account/create'" class="btn btn-primary">Create Account (+)</button>
            <button type="submit" class="btn btn-success">Login =></button>

        </div>
    </form>
</div>

