<div class="container-sm text-light">
    <br/>
    <div class="d-flex align-items-center">
        <a href="/">
            <p class="mb-0 me-2">Go to Blog Page
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-box-arrow-right" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/>
                    <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/>
                </svg>
            </p>
        </a>
    </div>
    <br/>
    <h1>(+) Create Account</h1>
    <div class="form-text text-dark">Note: It is mandatory to fill all fields</div>
    <br/>
    <br/>
    <br/>
    <form action="/account/create" method="post">

        <label>Choose your Avatar:</label>
        <br/>
        <div class="container-flex gap-10">
            {{#each avatars}}
                <label>
                    <input type="radio" name="avatarid" value="{{this.id}}" required>
                    <img src="{{this.imageData}}" alt="Avatar" width="80" height="80" >
                </label>
            {{/each}}
        </div>
        <br/>
        <div class="input-group has-validation">
            <span class="input-group-text bg-secondary text-light"> User ID </span>
            <input
                    type="text"
                    id="useridInput"
                    name="userid"
                    class="form-control"
                    placeholder="User ID..."
                    required
            >
            <div class="valid-feedback">
                That's a great username! It's available.
            </div>
            <div class="invalid-feedback" id="usernameErrorText">
                This username is already taken.
            </div>
        </div>
        <br/>
        <div class="input-group">
            <span class="input-group-text bg-secondary text-light">First and last name</span>
            <input type="text" name="firstname" class="form-control " placeholder="(first name)">
            <input type="text" name="lastname" class="form-control " placeholder="(last name)">
        </div>
        <br/>
        <div class="input-group">
            <span class="input-group-text bg-secondary text-light">Password:</span>
            <input type="password" name="password" class="form-control " placeholder="(Enter Password)">
            <input type="password" name="rpassword" class="form-control " placeholder="(Enter Same Password)">
        </div>
        <br/>
        <div class="input-group">
            <span class="input-group-text bg-secondary text-light">Date of Birth (Enter only in numbers)</span>
            <input type="text" name="date" class="form-control " placeholder="(Date Input)">
            <input type="text" name="month" class="form-control  " placeholder="(Month Input)">
            <input type="text" name="year" class="form-control " placeholder="(Year Input)">
        </div>
        <br/>
        <div class="input-group">
            <span class="input-group-text bg-secondary text-light"> Description </span>
            <textarea type="text" name="description" class="form-control" placeholder="Description"></textarea>
        </div>
        <br/>
        <button type="submit" class="btn btn-success">Submit and Login</button>

    </form>
</div>

<script>
    const useridInput = document.querySelector('#useridInput');
    let timeout = null;

    useridInput.addEventListener('input', () => {
        const userid = useridInput.value.trim();

        // Clear the previous timer if the user is still typing
        clearTimeout(timeout);

        // If input is empty, reset the styling
        if (!userid) {
            useridInput.classList.remove('is-valid', 'is-invalid');
            return;
        }

        // Wait 300ms after the user stops typing
        timeout = setTimeout(async () => {
            try {
                const response = await fetch(`/account/check-username/${userid}`);
                const data = await response.json();

                if (data.available) {
                    // Update Bootstrap classes for success
                    useridInput.classList.add('is-valid');
                    useridInput.classList.remove('is-invalid');
                } else {
                    // Update Bootstrap classes for error
                    useridInput.classList.add('is-invalid');
                    useridInput.classList.remove('is-valid');
                }
            } catch (err) {
                console.error("Username check failed:", err);
            }
        }, 300);
    });
</script>